# OpenAI (ChatGPT API)
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (litellm: gemini/ 제공자 — 보통 GEMINI_API_KEY)
GEMINI_API_KEY=...

# Ollama (로컬, 키 불필요 — 데몬만 실행 중이면 됨)
OLLAMA_API_BASE=http://127.0.0.1:11434

# 모델 ID (필요 시 변경)
CONSENSUS_MODEL_OPENAI=gpt-4o
CONSENSUS_MODEL_ANTHROPIC=anthropic/claude-3-5-sonnet-20241022
CONSENSUS_MODEL_GEMINI=gemini/gemini-2.0-flash
CONSENSUS_MODEL_OLLAMA=ollama/gemma3:4b

# 비용 절감: 마지막 라운드만 이 모델이 최종 선택 (미설정 시 ANTHROPIC 모델 사용)
# CONSENSUS_ARBITER_MODEL=anthropic/claude-3-5-haiku-20241022

# --- 보안 ---
# 이 파일을 채운 뒤 이름을 .env 로 저장하세요. .env 는 Git에 올라가지 않습니다.
